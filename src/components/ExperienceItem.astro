---
interface Props {
  date: string;
  job: string;
  title: string;
  description: string;
}
const { date, job, title, description } = Astro.props;
---

<div class="absolute size-3 bg-white rounded-full mt-1.5 -inset-s-1.5"></div>

<time class="text-sm leading-none text-white/80">{date}</time>
<h3 class="text-lg font-semibold text-blue-300 my-2">
  {title}<span class="text-white/80"> - {job}</span>
</h3>
<p class="mb-4 text-base font-normal text-white/80">{description}</p>
