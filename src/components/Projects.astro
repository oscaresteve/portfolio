---
import Angular from "../icons/Angular.astro";
import Tailwind from "../icons/Tailwind.astro";
import Html from "../icons/Html.astro";
import Css from "../icons/Css.astro";
import Supabase from "../icons/Supabase.astro";
import GitHub from "../icons/GitHub.astro";
import ExternalLink from "../icons/ExternalLink.astro";

const TAGS = {
  ANGULAR: {
    name: "Angular",
    icon: Angular,
  },
  TAILWIND: {
    name: "Tailwind CSS",
    icon: Tailwind,
  },
  HTML: {
    name: "HTML",
    icon: Html,
  },
  CSS: {
    name: "CSS",
    icon: Css,
  },
  SUPABASE: {
    name: "Supabase",
    icon: Supabase,
  },
};

const PROJECTS = [
  {
    title: "Solar",
    description: "Proyecto de Desarrollo en Entorno Cliente del curso 2º DAW",
    link: "https://solar-oscaresteve.vercel.app/#/home",
    github: "https://github.com/oscaresteve/solar",
    image: "/src/assets/solar.webp",
    tags: [TAGS.ANGULAR, TAGS.TAILWIND, TAGS.SUPABASE, TAGS.CSS, TAGS.HTML],
  },
];
---

{
  PROJECTS.map(({ title, description, link, github, image, tags }) => (
    <article>
      <h3 class="text-2xl font-semibold mb-2 text-blue-300">{title}</h3>
      <p class="text-lg text-pretty mb-4 text-white/80">{description}</p>
      <ul class="flex gap-x-2">
        {tags.map((tag) => (
          <li>
            <span class="flex items-center gap-x-2 rounded-full text-xs bg-white/5 border border-white/10 hover:border-white/15 py-1 px-2">
              <tag.icon class="size-3" />
              {tag.name}
            </span>
          </li>
        ))}
      </ul>
      <img
        class="hover:scale-101 transition duration-300 my-2"
        src={image}
        alt={`Captura de pantalla del proyecto ${title}`}
      />
      <div class="flex gap-x-2">
        <a
          href={link}
          class="rounded-xl border border-white/20 flex justify-center items-center gap-x-2 py-2 px-4 bg-white/5 hover:scale-105 transition hover:bg-white/10 cursor-pointer"
          target="_blank"
          rel="noopener"
        >
          <ExternalLink class="size-4" />
          Preview
        </a>
        <a
          href={github}
          class="rounded-xl border border-white/10 flex justify-center items-center gap-x-2 py-2 px-4 bg-white/5 hover:scale-105 transition hover:bg-white/10 cursor-pointer hover:border-white/20"
          target="_blank"
          rel="noopener"
        >
          <GitHub class="size-4" />
          Code
        </a>
      </div>
    </article>
  ))
}
